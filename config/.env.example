# Microsoft 365 OAuth Configuration
MICROSOFT_CLIENT_ID=my_client_id_from_azure_portal
MICROSOFT_CLIENT_SECRET=my_client_secret_from_azure_portal
MICROSOFT_REDIRECT_URI=http://localhost/student_violations/index.php?page=student_oauth_callback
MICROSOFT_TENANT=common

# Database Configuration (if not using hardcoded db_connection.php)
DB_SERVER=localhost
DB_DATABASE=my_database_name
DB_USERNAME=my_database_user
DB_PASSWORD=my_database_password

# Application Settings
APP_ENV=development
APP_DEBUG=true